<div class="card border-0 shadow-sm">
  <div class="card-body">
    <h5 class="card-title mb-3">Редактирование карточки</h5>

    <form method="POST" action="/wishlist/update/<%= item.id %>" class="row g-3" enctype="multipart/form-data">
      <div class="col-md-8">
        <label class="form-label">Название *</label>
        <input
          type="text"
          name="title"
          class="form-control"
          value="<%- item.title %>"
          required
        >
      </div>

      <div class="col-md-4">
        <label class="form-label">Цена *</label>
        <input
          type="number"
          step="0.01"
          name="amount"
          class="form-control"
          value="<%= Number(item.amount).toFixed(2) %>"
          required
        >
      </div>

      <div class="col-12">
        <label class="form-label">Ссылка на товар</label>
        <input
          type="text"
          name="store_url"
          class="form-control"
          value="<%- item.store_url || '' %>"
          placeholder="https://..."
        >
        <div class="form-text">
          Если у карточки нет своей картинки, система может попробовать снова подтянуть изображение со страницы товара.
        </div>
      </div>

      <div class="col-md-6">
        <label class="form-label">Ссылка на изображение</label>
        <input
          type="text"
          name="image_url"
          class="form-control"
          value="<%- item.image_url || '' %>"
          placeholder="https://..."
        >
      </div>

      <div class="col-md-6">
        <label class="form-label">Загрузить фото с компьютера</label>
        <input
          type="file"
          name="image_file"
          class="form-control"
          accept="image/*"
        >
      </div>

      <div class="col-md-6">
        <label class="form-label">Категория</label>
        <select name="category_id" class="form-select">
          <option value="none">Без категории</option>
          <% categories.forEach(c => { %>
            <option
              value="<%= c.id %>"
              <%= item.category_id && String(item.category_id) === String(c.id) ? 'selected' : '' %>
            >
              <%= c.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="col-md-6">
        <label class="form-label">Кто планирует</label>
        <select name="who" class="form-select">
          <option value="">Не указано</option>
          <% members.forEach(m => { %>
            <option
              value="<%- m.name %>"
              <%= item.who === m.name ? 'selected' : '' %>
            >
              <%- m.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="col-md-4">
        <label class="form-label">Дата</label>
        <input
          type="date"
          name="planned_date"
          class="form-control"
          value="<%= item.planned_date ? String(item.planned_date).slice(0, 10) : '' %>"
        >
      </div>

      <div class="col-md-4">
        <label class="form-label">Приоритет</label>
        <select name="priority" class="form-select">
          <option value="low" <%= item.priority === 'low' ? 'selected' : '' %>>Низкий</option>
          <option value="medium" <%= item.priority === 'medium' ? 'selected' : '' %>>Средний</option>
          <option value="high" <%= item.priority === 'high' ? 'selected' : '' %>>Высокий</option>
        </select>
      </div>

      <div class="col-md-4">
        <label class="form-label">Статус</label>
        <select name="status" class="form-select">
          <option value="planned" <%= item.status === 'planned' ? 'selected' : '' %>>Запланировано</option>
          <option value="postponed" <%= item.status === 'postponed' ? 'selected' : '' %>>Отложено</option>
          <option value="bought" <%= item.status === 'bought' ? 'selected' : '' %>>Куплено</option>
          <option value="cancelled" <%= item.status === 'cancelled' ? 'selected' : '' %>>Отменено</option>
        </select>
      </div>

      <div class="col-12">
        <label class="form-label">Описание</label>
        <textarea
          name="description"
          class="form-control"
          rows="4"
          placeholder="Описание, заметки, характеристики"
        ><%- item.description || '' %></textarea>
      </div>

      <div class="col-12 d-flex flex-wrap gap-2">
        <button type="submit" class="btn btn-primary">
          Сохранить изменения
        </button>
      </div>
    </form>

    <hr>

    <div class="d-flex flex-wrap gap-2">
      <form method="POST" action="/wishlist/status" class="d-inline">
        <input type="hidden" name="id" value="<%= item.id %>">
        <input type="hidden" name="status" value="planned">
        <button type="submit" class="btn btn-outline-primary btn-sm">
          Вернуть в план
        </button>
      </form>

      <form method="POST" action="/wishlist/status" class="d-inline">
        <input type="hidden" name="id" value="<%= item.id %>">
        <input type="hidden" name="status" value="postponed">
        <button type="submit" class="btn btn-outline-warning btn-sm">
          Отложить
        </button>
      </form>

      <form method="POST" action="/wishlist/status" class="d-inline">
        <input type="hidden" name="id" value="<%= item.id %>">
        <input type="hidden" name="status" value="bought">
        <button type="submit" class="btn btn-outline-success btn-sm">
          Отметить купленным
        </button>
      </form>

      <form method="POST" action="/wishlist/delete" class="d-inline" onsubmit="return confirm('Удалить эту карточку wishlist?')">
        <input type="hidden" name="id" value="<%= item.id %>">
        <button type="submit" class="btn btn-outline-danger btn-sm">
          Удалить
        </button>
      </form>
    </div>
  </div>
</div>