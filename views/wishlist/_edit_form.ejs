<div class="card border-0 shadow-sm">
  <div class="card-body">
    <h5 class="card-title mb-3">Редактирование карточки</h5>

    <form method="POST" action="/wishlist/update/<%= item.id %>" class="row g-3" id="wishlist-edit-form" enctype="multipart/form-data">
      <div class="col-md-8">
        <label class="form-label">Название *</label>
        <input
          type="text"
          name="title"
          class="form-control"
          value="<%- item.title %>"
          required
        >
      </div>

      <div class="col-md-4">
        <label class="form-label">Цена *</label>
        <input
          type="number"
          step="0.01"
          min="0.01"
          name="amount"
          class="form-control"
          value="<%= Number(item.amount).toFixed(2) %>"
          required
        >
      </div>

      <div class="col-md-6">
        <label class="form-label">Фото товара</label>
        <input
          type="text"
          name="image_url"
          class="form-control"
          value="<%- item.image_url || '' %>"
          placeholder="https://..."
        >
      </div>

      <div class="col-md-6">
        <label class="form-label">Загрузить фото с устройства</label>
        <input
          type="file"
          name="image_file"
          class="form-control"
          accept="image/*"
        >
        <div class="form-text">
          Если выбрать файл, он заменит текущую ссылку на изображение.
        </div>
      </div>

      <div class="col-md-6">
        <label class="form-label">Ссылка на магазин</label>
        <input
          type="text"
          name="store_url"
          class="form-control"
          value="<%- item.store_url || '' %>"
          placeholder="https://..."
        >
      </div>

      <div class="col-12">
        <div id="wishlist-edit-image-preview-wrap" class="<%= item.image_url ? '' : 'd-none' %>">
          <label class="form-label">Предварительная картинка</label>
          <div class="border rounded-3 p-2 text-center bg-light">
            <img
              id="wishlist-edit-image-preview"
              src="<%- item.image_url || '' %>"
              alt="Предпросмотр"
              style="max-width: 100%; max-height: 220px; object-fit: contain;"
            >
          </div>
          <div class="form-text">
            Картинка подставилась автоматически. Вы можете вручную заменить ссылку в поле «Фото товара».
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <label class="form-label">Категория</label>
        <select name="category_id" class="form-select">
          <option value="none">Без категории</option>
          <% categories.forEach(c => { %>
            <option
              value="<%= c.id %>"
              <%= item.category_id && String(item.category_id) === String(c.id) ? 'selected' : '' %>
            >
              <%= c.name %>
            </option>
          <% }) %>
        </select>
        <div class="form-text">
          Если сохранить без категории, автоматически будет использована категория WishList.
        </div>
      </div>

      <div class="col-md-6">
        <label class="form-label">Кто планирует</label>
        <select name="who" class="form-select">
          <option value="">Не указано</option>
          <% members.forEach(m => { %>
            <option
              value="<%- m.name %>"
              <%= item.who === m.name ? 'selected' : '' %>
            >
              <%- m.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="col-md-4">
        <label class="form-label">Дата</label>
        <input
          type="date"
          name="planned_date"
          class="form-control"
          value="<%= item.planned_date ? String(item.planned_date).slice(0, 10) : '' %>"
        >
      </div>

      <div class="col-md-4">
        <label class="form-label">Приоритет</label>
        <select name="priority" class="form-select">
          <option value="low" <%= item.priority === 'low' ? 'selected' : '' %>>Низкий</option>
          <option value="medium" <%= item.priority === 'medium' ? 'selected' : '' %>>Средний</option>
          <option value="high" <%= item.priority === 'high' ? 'selected' : '' %>>Высокий</option>
        </select>
      </div>

      <div class="col-md-4">
        <label class="form-label">Статус</label>
        <select name="status" class="form-select">
          <option value="planned" <%= item.status === 'planned' ? 'selected' : '' %>>Запланировано</option>
          <option value="postponed" <%= item.status === 'postponed' ? 'selected' : '' %>>Отложено</option>
          <option value="bought" <%= item.status === 'bought' ? 'selected' : '' %>>Куплено</option>
          <option value="cancelled" <%= item.status === 'cancelled' ? 'selected' : '' %>>Отменено</option>
        </select>
      </div>

      <div class="col-12">
        <label class="form-label">Описание</label>
        <textarea
          name="description"
          class="form-control"
          rows="4"
          placeholder="Описание, заметки, характеристики"
        ><%- item.description || '' %></textarea>
      </div>

      <div class="col-12 d-flex flex-wrap gap-2">
        <button type="submit" class="btn btn-primary">
          Сохранить изменения
        </button>
      </div>
    </form>

    <hr>

    <div class="d-flex flex-wrap gap-2">
      <form method="POST" action="/wishlist/status" class="d-inline">
        <input type="hidden" name="id" value="<%= item.id %>">
        <input type="hidden" name="status" value="planned">
        <button type="submit" class="btn btn-outline-primary btn-sm">
          Вернуть в план
        </button>
      </form>

      <form method="POST" action="/wishlist/status" class="d-inline">
        <input type="hidden" name="id" value="<%= item.id %>">
        <input type="hidden" name="status" value="postponed">
        <button type="submit" class="btn btn-outline-warning btn-sm">
          Отложить
        </button>
      </form>

      <form method="POST" action="/wishlist/status" class="d-inline">
        <input type="hidden" name="id" value="<%= item.id %>">
        <input type="hidden" name="status" value="bought">
        <button type="submit" class="btn btn-outline-success btn-sm">
          Отметить купленным
        </button>
      </form>

      <form method="POST" action="/wishlist/delete" class="d-inline" onsubmit="return confirm('Удалить эту карточку wishlist?')">
        <input type="hidden" name="id" value="<%= item.id %>">
        <button type="submit" class="btn btn-outline-danger btn-sm">
          Удалить
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('wishlist-edit-form');
    if (!form) return;

    const storeUrlInput = form.querySelector('input[name="store_url"]');
    const imageUrlInput = form.querySelector('input[name="image_url"]');
    const imageFileInput = form.querySelector('input[name="image_file"]');
    const previewWrap = document.getElementById('wishlist-edit-image-preview-wrap');
    const previewImg = document.getElementById('wishlist-edit-image-preview');

    if (!storeUrlInput || !imageUrlInput || !imageFileInput || !previewWrap || !previewImg) {
      return;
    }

    let timer = null;

    function showPreview(url) {
      if (!url) {
        previewImg.src = '';
        previewWrap.classList.add('d-none');
        return;
      }

      previewImg.src = url;
      previewWrap.classList.remove('d-none');
    }

    imageUrlInput.addEventListener('input', function () {
      const manualUrl = imageUrlInput.value.trim();

      if (manualUrl) {
        imageFileInput.value = '';
        showPreview(manualUrl);
      } else if (!imageFileInput.files.length) {
        showPreview('');
      }
    });

    imageFileInput.addEventListener('change', function () {
      const file = imageFileInput.files && imageFileInput.files[0];

      if (!file) {
        if (imageUrlInput.value.trim()) {
          showPreview(imageUrlInput.value.trim());
        } else {
          showPreview('');
        }
        return;
      }

      imageUrlInput.value = '';

      const reader = new FileReader();
      reader.onload = function (e) {
        showPreview(e.target.result);
      };
      reader.readAsDataURL(file);
    });

    storeUrlInput.addEventListener('blur', function () {
      const storeUrl = storeUrlInput.value.trim();
      if (!storeUrl || imageFileInput.files.length || imageUrlInput.value.trim()) return;

      clearTimeout(timer);

      timer = setTimeout(async () => {
        try {
          const response = await fetch(`/wishlist/preview-image?store_url=${encodeURIComponent(storeUrl)}`);
          const data = await response.json();

          if (data && data.success && data.image_url) {
            imageUrlInput.value = data.image_url;
            showPreview(data.image_url);
          }
        } catch (err) {
        }
      }, 250);
    });

    if (imageUrlInput.value.trim()) {
      showPreview(imageUrlInput.value.trim());
    }
  });
</script>