<%- include('../partials/header', { user, activePage: 'wishlist' }) %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <h2 class="mb-1">Wishlist</h2>
    <p class="text-muted mb-0">
      Быстрый список желаний и планируемых покупок семьи.
    </p>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100 wishlist-stat-card">
      <div class="card-body">
        <div class="small text-muted">Всего карточек</div>
        <div class="fs-4 fw-semibold"><%= summary.totalItems %></div>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100 wishlist-stat-card">
      <div class="card-body">
        <div class="small text-muted">Запланировано</div>
        <div class="fs-4 fw-semibold"><%= Number(summary.plannedTotal).toFixed(2) %> €</div>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100 wishlist-stat-card">
      <div class="card-body">
        <div class="small text-muted">Свободно после плана</div>
        <div class="fs-4 fw-semibold <%= summary.freeAfterPlanned < 0 ? 'text-danger' : 'text-success' %>">
          <%= Number(summary.freeAfterPlanned).toFixed(2) %> €
        </div>
      </div>
    </div>
  </div>
</div>

<div class="mb-4">
  <%- include('_filters', { categories, filters }) %>
</div>

<%- include('_cards', { wishlist }) %>

<div
  class="modal fade"
  id="wishlistAddModal"
  tabindex="-1"
  aria-labelledby="wishlistAddModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content border-0 shadow-lg rounded-4">
      <div class="modal-header border-0 pb-0">
        <div>
          <h5 class="modal-title" id="wishlistAddModalLabel">Новая карточка</h5>
          <div class="text-muted small">Заполните только основное, остальное можно добавить позже.</div>
        </div>

        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
          aria-label="Закрыть"
        ></button>
      </div>

      <div class="modal-body pt-3">
        <%- include('_quick_add', { categories, members }) %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>