<%- include('../partials/header', { user, activePage: 'wishlist' }) %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
  <div>
    <h2 class="mb-1">Wishlist</h2>
    <p class="text-muted mb-0">
      Быстрый список желаний и планируемых покупок семьи.
    </p>
  </div>

  <button
    class="btn btn-dark"
    type="button"
    data-bs-toggle="collapse"
    data-bs-target="#wishlistAddCollapse"
    aria-expanded="false"
    aria-controls="wishlistAddCollapse"
  >
    <i class="bi bi-plus-lg me-1"></i>
    Добавить карточку
  </button>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100 wishlist-stat-card">
      <div class="card-body">
        <div class="small text-muted">Всего карточек</div>
        <div class="fs-4 fw-semibold"><%= summary.totalItems %></div>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100 wishlist-stat-card">
      <div class="card-body">
        <div class="small text-muted">Запланировано</div>
        <div class="fs-4 fw-semibold"><%= Number(summary.plannedTotal).toFixed(2) %> €</div>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100 wishlist-stat-card">
      <div class="card-body">
        <div class="small text-muted">Свободно после плана</div>
        <div class="fs-4 fw-semibold <%= summary.freeAfterPlanned < 0 ? 'text-danger' : 'text-success' %>">
          <%= Number(summary.freeAfterPlanned).toFixed(2) %> €
        </div>
      </div>
    </div>
  </div>
</div>

<div class="collapse mb-4" id="wishlistAddCollapse">
  <%- include('_quick_add', { categories, members }) %>
</div>

<div class="mb-4">
  <%- include('_filters', { categories, filters }) %>
</div>

<%- include('_cards', { wishlist }) %>

<%- include('../partials/footer') %>