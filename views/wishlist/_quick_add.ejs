    async function fetchPreviewMeta() {
      const rawUrl = storeUrlInput.value.trim();
      if (!rawUrl || rawUrl === lastFetchedUrl) return;

      if (imageFileInput && imageFileInput.files && imageFileInput.files.length > 0) {
        return;
      }

      lastFetchedUrl = rawUrl;

      try {
        const response = await fetch(`/wishlist/preview-meta?url=${encodeURIComponent(rawUrl)}`, {
          headers: {
            'X-Requested-With': 'XMLHttpRequest'
          }
        });

        const data = await response.json();

        if (!data || !data.ok) return;

        if (!titleTouched && !titleInput.value.trim() && data.title) {
          titleInput.value = data.title;
        }

        if (!amountTouched && !amountInput.value.trim() && data.amount) {
          amountInput.value = data.amount;
        }

        if (
          imageUrlInput &&
          !imageUrlInput.value.trim() &&
          !(imageFileInput && imageFileInput.files && imageFileInput.files.length > 0) &&
          data.image
        ) {
          imageUrlInput.value = data.image;
        }
      } catch (err) {
        // ignore
      }
    }

    storeUrlInput.addEventListener('blur', fetchPreviewMeta);

    storeUrlInput.addEventListener('input', function () {
      clearTimeout(requestTimer);
      requestTimer = setTimeout(fetchPreviewMeta, 700);
