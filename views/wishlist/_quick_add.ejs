<div class="card border-0 shadow-sm wishlist-quick-card">
  <div class="card-body p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h5 class="card-title mb-1">Новая карточка</h5>
        <div class="text-muted small">Заполните только основное, остальное можно добавить позже.</div>
      </div>
    </div>

    <form
      method="POST"
      action="/wishlist"
      class="row g-3"
      id="wishlist-quick-add-form"
      enctype="multipart/form-data"
    >
      <div class="col-md-8">
        <label class="form-label">Название *</label>
        <input
          type="text"
          name="title"
          class="form-control"
          placeholder="Например: Наушники Sony WH-1000XM5"
          required
        >
      </div>

      <div class="col-md-4">
        <label class="form-label">Цена *</label>
        <input
          type="number"
          step="0.01"
          min="0.01"
          name="amount"
          class="form-control"
          placeholder="0.00"
          required
        >
      </div>

      <div class="col-md-6">
        <label class="form-label">Ссылка на магазин</label>
        <input
          type="text"
          name="store_url"
          class="form-control"
          placeholder="https://..."
        >
      </div>

      <div class="col-md-6">
        <label class="form-label">Ссылка на фото</label>
        <input
          type="text"
          name="image_url"
          class="form-control"
          placeholder="https://..."
        >
      </div>

      <div class="col-12">
        <label class="form-label">Загрузить фото с устройства</label>
        <input
          type="file"
          name="image_file"
          class="form-control"
          accept="image/*"
        >
        <div class="form-text">
          Если загрузить файл, он будет использован вместо ссылки на изображение.
        </div>
      </div>

      <div class="col-12">
        <div id="wishlist-image-preview-wrap" class="d-none">
          <label class="form-label">Предварительная картинка</label>
          <div class="border rounded-4 p-2 text-center bg-light">
            <img
              id="wishlist-image-preview"
              src=""
              alt="Предпросмотр"
              class="wishlist-preview-image"
            >
          </div>
          <div class="form-text">
            Картинка подставилась автоматически. Можно оставить её, заменить ссылкой или загрузить файл.
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <label class="form-label">Категория</label>
        <select name="category_id" class="form-select">
          <option value="none" selected>Без категории</option>
          <% categories.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% }) %>
        </select>
        <div class="form-text">
          Если не выбрать категорию, автоматически будет создана категория WishList.
        </div>
      </div>

      <div class="col-md-6">
        <label class="form-label">Дата покупки</label>
        <input
          type="date"
          name="planned_date"
          class="form-control"
        >
      </div>

      <div class="col-12">
        <details class="wishlist-more-fields border rounded-4 p-3">
          <summary>Дополнительно</summary>

          <div class="row g-3 mt-2">
            <div class="col-12">
              <label class="form-label">Описание</label>
              <textarea
                name="description"
                class="form-control"
                rows="3"
                placeholder="Описание, заметки, характеристики"
              ></textarea>
            </div>

            <div class="col-md-6">
              <label class="form-label">Кто планирует</label>
              <select name="who" class="form-select">
                <option value="">Не указано</option>
                <% members.forEach(m => { %>
                  <option value="<%- m.name %>"><%- m.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="col-md-6">
              <label class="form-label">Приоритет</label>
              <select name="priority" class="form-select">
                <option value="low">Низкий</option>
                <option value="medium" selected>Средний</option>
                <option value="high">Высокий</option>
              </select>
            </div>
          </div>
        </details>
      </div>

      <div class="col-12 d-flex justify-content-end">
        <button type="submit" class="btn btn-primary px-4">
          Добавить карточку
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('wishlist-quick-add-form');
    if (!form) return;

    const storeUrlInput = form.querySelector('input[name="store_url"]');
    const imageUrlInput = form.querySelector('input[name="image_url"]');
    const imageFileInput = form.querySelector('input[name="image_file"]');
    const previewWrap = document.getElementById('wishlist-image-preview-wrap');
    const previewImg = document.getElementById('wishlist-image-preview');

    if (!storeUrlInput || !imageUrlInput || !imageFileInput || !previewWrap || !previewImg) {
      return;
    }

    let timer = null;

    function showPreview(url) {
      if (!url) {
        previewImg.src = '';
        previewWrap.classList.add('d-none');
        return;
      }

      previewImg.src = url;
      previewWrap.classList.remove('d-none');
    }

    imageUrlInput.addEventListener('input', function () {
      const manualUrl = imageUrlInput.value.trim();

      if (manualUrl) {
        imageFileInput.value = '';
        showPreview(manualUrl);
      } else if (!imageFileInput.files.length) {
        showPreview('');
      }
    });

    imageFileInput.addEventListener('change', function () {
      const file = imageFileInput.files && imageFileInput.files[0];

      if (!file) {
        if (imageUrlInput.value.trim()) {
          showPreview(imageUrlInput.value.trim());
        } else {
          showPreview('');
        }
        return;
      }

      imageUrlInput.value = '';

      const reader = new FileReader();
      reader.onload = function (e) {
        showPreview(e.target.result);
      };
      reader.readAsDataURL(file);
    });

    storeUrlInput.addEventListener('blur', function () {
      const storeUrl = storeUrlInput.value.trim();
      if (!storeUrl || imageFileInput.files.length || imageUrlInput.value.trim()) return;

      clearTimeout(timer);

      timer = setTimeout(async () => {
        try {
          const response = await fetch(`/wishlist/preview-image?store_url=${encodeURIComponent(storeUrl)}`);
          const data = await response.json();

          if (data && data.success && data.image_url) {
            imageUrlInput.value = data.image_url;
            showPreview(data.image_url);
          }
        } catch (err) {
        }
      }, 250);
    });

    if (imageUrlInput.value.trim()) {
      showPreview(imageUrlInput.value.trim());
    }
  });
</script>