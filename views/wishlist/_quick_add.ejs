<div class="card border-0 shadow-sm wishlist-quick-card">
  <div class="card-body">
    <h5 class="card-title mb-3">Быстро добавить</h5>

    <form method="POST" action="/wishlist" class="row g-3" enctype="multipart/form-data">
      <div class="col-12">
        <label class="form-label">Название *</label>
        <input
          type="text"
          name="title"
          class="form-control"
          placeholder="Например: iPad Air"
          required
        >
      </div>

      <div class="col-12">
        <label class="form-label">Цена *</label>
        <input
          type="number"
          step="0.01"
          name="amount"
          class="form-control"
          placeholder="0.00"
          required
        >
      </div>

      <div class="col-12">
        <label class="form-label">Ссылка на товар</label>
        <input
          type="text"
          name="store_url"
          class="form-control"
          placeholder="https://..."
        >
        <div class="form-text">
          Можно вставить ссылку на страницу товара. Система попробует автоматически подтянуть главное изображение.
        </div>
      </div>

      <div class="col-12">
        <label class="form-label">Ссылка на изображение</label>
        <input
          type="text"
          name="image_url"
          class="form-control"
          placeholder="https://..."
        >
        <div class="form-text">
          Используйте это поле, если хотите сразу поставить свою картинку по ссылке.
        </div>
      </div>

      <div class="col-12">
        <label class="form-label">Загрузить фото с компьютера</label>
        <input
          type="file"
          name="image_file"
          class="form-control"
          accept="image/*"
        >
        <div class="form-text">
          Загруженный файл имеет приоритет над внешней ссылкой на изображение.
        </div>
      </div>

      <div class="col-12">
        <details class="wishlist-more-fields">
          <summary>Дополнительные поля</summary>

          <div class="row g-3 mt-2">
            <div class="col-12">
              <label class="form-label">Категория</label>
              <select name="category_id" class="form-select">
                <option value="none">Без категории</option>
                <% categories.forEach(c => { %>
                  <option value="<%= c.id %>"><%= c.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="col-12">
              <label class="form-label">Описание</label>
              <textarea
                name="description"
                class="form-control"
                rows="3"
                placeholder="Короткая заметка"
              ></textarea>
            </div>

            <div class="col-md-6">
              <label class="form-label">Дата</label>
              <input
                type="date"
                name="planned_date"
                class="form-control"
              >
            </div>

            <div class="col-md-6">
              <label class="form-label">Кто планирует</label>
              <select name="who" class="form-select">
                <option value="">Не указано</option>
                <% members.forEach(m => { %>
                  <option value="<%- m.name %>"><%- m.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="col-12">
              <label class="form-label">Приоритет</label>
              <select name="priority" class="form-select">
                <option value="low">Низкий</option>
                <option value="medium" selected>Средний</option>
                <option value="high">Высокий</option>
              </select>
            </div>
          </div>
        </details>
      </div>

      <div class="col-12">
        <button type="submit" class="btn btn-primary w-100">
          Добавить карточку
        </button>
      </div>
    </form>
  </div>
</div>