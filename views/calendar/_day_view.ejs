<div class="card border-0 shadow-sm">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
      <div>
        <h5 class="mb-1">Дневник на <%= formattedSelectedDate %></h5>
        <div class="text-muted small">
          Подробный список событий и задач на выбранный день
        </div>
      </div>

      <a href="/calendar?view=month&date=<%= selectedDate %>" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-grid-3x3-gap me-1"></i>
        К месяцу
      </a>
    </div>

    <% if (!dayEvents || dayEvents.length === 0) { %>
      <div class="calendar-empty-state text-center py-5">
        <div class="mb-2">
          <i class="bi bi-calendar-x fs-1 text-muted"></i>
        </div>
        <h6 class="mb-1">На этот день пока ничего не запланировано</h6>
        <p class="text-muted mb-0">Добавь событие слева, и оно появится в дневнике.</p>
      </div>
    <% } else { %>
      <div class="calendar-diary-list">
        <% dayEvents.forEach(function(event, index) { %>
          <div class="calendar-diary-card <%= event.is_completed ? 'calendar-diary-card-completed' : '' %>" style="border-left-color: <%= event.color || '#0d6efd' %>;">
            <div class="calendar-diary-top">
              <div>
                <div class="calendar-diary-title <%= event.is_completed ? 'calendar-text-completed' : '' %>">
                  <%= event.title %>
                </div>

                <div class="calendar-diary-meta text-muted">
                  <% if (Number(event.is_all_day) === 1) { %>
                    <span class="me-2"><i class="bi bi-sun me-1"></i>Весь день</span>
                  <% } else if (event.start_time && event.end_time) { %>
                    <span class="me-2">
                      <i class="bi bi-clock me-1"></i>
                      <%= String(event.start_time).slice(0, 5) %> – <%= String(event.end_time).slice(0, 5) %>
                    </span>
                  <% } else if (event.start_time) { %>
                    <span class="me-2">
                      <i class="bi bi-clock me-1"></i>
                      <%= String(event.start_time).slice(0, 5) %>
                    </span>
                  <% } %>

                  <span class="me-2">
                    <i class="bi bi-bookmark me-1"></i>
                    <%= event.event_type_label %>
                  </span>

                  <% if (event.member_name) { %>
                    <span class="me-2">
                      <i class="bi bi-person me-1"></i>
                      <%= event.member_name %>
                    </span>
                  <% } %>

                  <% if (event.is_completed) { %>
                    <span class="badge text-bg-success-subtle border">
                      <i class="bi bi-check2-circle me-1"></i>
                      Выполнено
                    </span>
                  <% } %>
                </div>
              </div>

              <div class="d-flex gap-2 flex-wrap">
                <button
                  type="button"
                  class="btn btn-outline-primary btn-sm"
                  data-bs-toggle="collapse"
                  data-bs-target="#edit-event-<%= event.id %>"
                  aria-expanded="false"
                  aria-controls="edit-event-<%= event.id %>"
                  title="Редактировать событие"
                >
                  <i class="bi bi-pencil"></i>
                </button>

                <form method="POST" action="/calendar/complete">
                  <input type="hidden" name="id" value="<%= event.id %>">
                  <input type="hidden" name="redirect_view" value="day">
                  <input type="hidden" name="redirect_date" value="<%= selectedDate %>">
                  <button
                    type="submit"
                    class="btn btn-sm <%= event.is_completed ? 'btn-outline-secondary' : 'btn-outline-success' %>"
                    title="<%= event.is_completed ? 'Снять отметку выполнения' : 'Отметить как выполненное' %>"
                  >
                    <i class="bi <%= event.is_completed ? 'bi-arrow-counterclockwise' : 'bi-check2' %>"></i>
                  </button>
                </form>

                <form method="POST" action="/calendar/delete" onsubmit="return confirm('Удалить событие?');">
                  <input type="hidden" name="id" value="<%= event.id %>">
                  <input type="hidden" name="redirect_view" value="day">
                  <input type="hidden" name="redirect_date" value="<%= selectedDate %>">
                  <button type="submit" class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </div>
            </div>

            <% if (event.description) { %>
              <div class="calendar-diary-description mt-2 <%= event.is_completed ? 'calendar-text-completed' : '' %>">
                <%= event.description %>
              </div>
            <% } %>

            <% if (Number(event.is_recurring) === 1 && event.recurring_type !== 'none') { %>
              <div class="mt-2">
                <span class="badge text-bg-light border">
                  <i class="bi bi-arrow-repeat me-1"></i>
                  Повтор: <%= event.recurring_type %>
                </span>
              </div>
            <% } %>

            <div class="collapse mt-3" id="edit-event-<%= event.id %>">
              <div class="card card-body bg-light border-0">
                <form method="POST" action="/calendar/update">
                  <input type="hidden" name="id" value="<%= event.id %>">
                  <input type="hidden" name="redirect_view" value="day">

                  <div class="row g-3">
                    <div class="col-12">
                      <label class="form-label">Название</label>
                      <input
                        type="text"
                        name="title"
                        class="form-control"
                        value="<%= event.title %>"
                        required
                      >
                    </div>

                    <div class="col-md-6">
                      <label class="form-label">Дата</label>
                      <input
                        type="date"
                        name="event_date"
                        class="form-control"
                        value="<%= event.event_date %>"
                        required
                      >
                    </div>

                    <div class="col-md-6">
                      <label class="form-label">Тип</label>
                      <select name="event_type" class="form-select">
                        <option value="event" <%= event.event_type === 'event' ? 'selected' : '' %>>Событие</option>
                        <option value="birthday" <%= event.event_type === 'birthday' ? 'selected' : '' %>>День рождения</option>
                        <option value="reminder" <%= event.event_type === 'reminder' ? 'selected' : '' %>>Напоминание</option>
                        <option value="task" <%= event.event_type === 'task' ? 'selected' : '' %>>Задача</option>
                      </select>
                    </div>

                    <div class="col-md-6">
                      <label class="form-label">Для кого</label>
                      <select name="member_name" class="form-select">
                        <option value="">Без привязки</option>
                        <% if (members && members.length > 0) { %>
                          <% members.forEach(function(m) { %>
                            <option value="<%- m.name %>" <%= event.member_name === m.name ? 'selected' : '' %>><%- m.name %></option>
                          <% }) %>
                        <% } %>
                      </select>
                    </div>

                    <div class="col-md-6">
                      <label class="form-label">Цвет</label>
                      <input
                        type="color"
                        name="color"
                        class="form-control form-control-color"
                        value="<%= event.color || '#0d6efd' %>"
                      >
                    </div>

                    <div class="col-12">
                      <div class="form-check">
                        <input
                          class="form-check-input edit-all-day-toggle"
                          type="checkbox"
                          value="1"
                          id="edit-all-day-<%= event.id %>"
                          name="is_all_day"
                          <%= Number(event.is_all_day) === 1 ? 'checked' : '' %>
                          data-target="#edit-time-row-<%= event.id %>"
                        >
                        <label class="form-check-label" for="edit-all-day-<%= event.id %>">
                          Весь день
                        </label>
                      </div>
                    </div>

                    <div class="col-12">
                      <div class="row g-3" id="edit-time-row-<%= event.id %>" style="<%= Number(event.is_all_day) === 1 ? 'display:none;' : '' %>">
                        <div class="col-md-6">
                          <label class="form-label">Начало</label>
                          <input
                            type="time"
                            name="start_time"
                            class="form-control"
                            value="<%= event.start_time ? String(event.start_time).slice(0,5) : '' %>"
                          >
                        </div>
                        <div class="col-md-6">
                          <label class="form-label">Конец</label>
                          <input
                            type="time"
                            name="end_time"
                            class="form-control"
                            value="<%= event.end_time ? String(event.end_time).slice(0,5) : '' %>"
                          >
                        </div>
                      </div>
                    </div>

                    <div class="col-12">
                      <div class="form-check mb-2">
                        <input
                          class="form-check-input edit-recurring-toggle"
                          type="checkbox"
                          value="1"
                          id="edit-recurring-<%= event.id %>"
                          name="is_recurring"
                          <%= Number(event.is_recurring) === 1 ? 'checked' : '' %>
                          data-target="#edit-recurring-type-<%= event.id %>"
                        >
                        <label class="form-check-label" for="edit-recurring-<%= event.id %>">
                          Повторяющееся событие
                        </label>
                      </div>

                      <label class="form-label">Повтор</label>
                      <select
                        name="recurring_type"
                        class="form-select"
                        id="edit-recurring-type-<%= event.id %>"
                        <%= Number(event.is_recurring) === 1 ? '' : 'disabled' %>
                      >
                        <option value="none" <%= event.recurring_type === 'none' ? 'selected' : '' %>>Без повтора</option>
                        <option value="daily" <%= event.recurring_type === 'daily' ? 'selected' : '' %>>Каждый день</option>
                        <option value="weekly" <%= event.recurring_type === 'weekly' ? 'selected' : '' %>>Каждую неделю</option>
                        <option value="monthly" <%= event.recurring_type === 'monthly' ? 'selected' : '' %>>Каждый месяц</option>
                        <option value="yearly" <%= event.recurring_type === 'yearly' ? 'selected' : '' %>>Каждый год</option>
                      </select>
                    </div>

                    <div class="col-12">
                      <label class="form-label">Описание</label>
                      <textarea
                        name="description"
                        class="form-control"
                        rows="3"
                      ><%= event.description || '' %></textarea>
                    </div>

                    <div class="col-12 d-flex gap-2">
                      <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-save me-1"></i>
                        Сохранить
                      </button>

                      <button
                        type="button"
                        class="btn btn-outline-secondary btn-sm"
                        data-bs-toggle="collapse"
                        data-bs-target="#edit-event-<%= event.id %>"
                      >
                        Отмена
                      </button>
                    </div>
                  </div>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.edit-all-day-toggle').forEach(function (checkbox) {
      function toggleRow() {
        const target = document.querySelector(checkbox.dataset.target);
        if (!target) return;
        target.style.display = checkbox.checked ? 'none' : '';
      }

      toggleRow();
      checkbox.addEventListener('change', toggleRow);
    });

    document.querySelectorAll('.edit-recurring-toggle').forEach(function (checkbox) {
      function toggleRecurring() {
        const target = document.querySelector(checkbox.dataset.target);
        if (!target) return;
        target.disabled = !checkbox.checked;
        if (!checkbox.checked) {
          target.value = 'none';
        }
      }

      toggleRecurring();
      checkbox.addEventListener('change', toggleRecurring);
    });
  });
</script>