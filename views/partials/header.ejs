<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Family Budget</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Bootstrap CSS -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >

  <!-- Bootstrap Icons -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
  >

  <!-- Твои кастомные стили -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">

<%
  const currentPage = typeof activePage !== 'undefined' ? activePage : '';
%>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    
    <!-- Логотип -->
    <a class="navbar-brand" href="/">
      Family Budget
    </a>

    <!-- Мобильная кнопка -->
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#mainNavbar"
      aria-controls="mainNavbar"
      aria-expanded="false"
      aria-label="Переключить навигацию"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNavbar">

      <!-- Левое меню -->
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">

        <% if (user) { %>

          <li class="nav-item">
            <a
              class="nav-link <%= currentPage === 'dashboard' ? 'active' : '' %>"
              href="/"
            >
              Дашборд
            </a>
          </li>

          <li class="nav-item">
            <a
              class="nav-link <%= currentPage === 'transactions' ? 'active' : '' %>"
              href="/transactions"
            >
              Транзакции
            </a>
          </li>

          <li class="nav-item">
            <a
              class="nav-link <%= currentPage === 'categories' ? 'active' : '' %>"
              href="/categories"
            >
              Категории
            </a>
          </li>

          <li class="nav-item">
            <a
              class="nav-link <%= currentPage === 'family' ? 'active' : '' %>"
              href="/family"
              title="Участники семьи"
            >
              <i class="bi bi-people me-1"></i>
              Семья
            </a>
          </li>

        <% } %>

      </ul>

      <!-- Правое меню -->
      <ul class="navbar-nav ms-auto">

        <% if (user) { %>

          <li class="nav-item">
            <span class="navbar-text me-2">
              <i class="bi bi-person-circle me-1"></i>
              <%= user.email %>
            </span>
          </li>

          <li class="nav-item">
            <a class="btn btn-outline-light btn-sm" href="/logout">
              Выйти
            </a>
          </li>

        <% } else { %>

          <li class="nav-item me-2">
            <a class="btn btn-outline-light btn-sm" href="/login">Вход</a>
          </li>

          <li class="nav-item">
            <a class="btn btn-success btn-sm" href="/register">Регистрация</a>
          </li>

        <% } %>

      </ul>

    </div>
  </div>
</nav>

<main class="container py-4">